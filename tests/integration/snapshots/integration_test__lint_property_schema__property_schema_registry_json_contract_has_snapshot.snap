expression: "format!(\"schema_id: {}\\n\\\n         title: {}\\n\\\n         registry_properties: {}\\n\\\n         contract_properties: {}\\n\\\n         field_properties: {}\\n\\\n         value_rule_options: {}\\n\\\n         fixture_schema: {}\\n\\\n         fixture_contracts: {}\\n\\\n         fixture_first_contract: {}\\n\\\n         fixture_fields: {}\\n\",\nschema[\"$id\"].as_str().unwrap(), schema[\"title\"].as_str().unwrap(),\nregistry_properties.join(\", \"), contract_properties.join(\", \"),\nfield_properties.join(\", \"), value_rule_options,\nfixture[\"$schema\"].as_str().unwrap(), fixture_contracts.len(),\nfixture_contracts[0][\"id\"].as_str().unwrap(), fixture_fields)"
